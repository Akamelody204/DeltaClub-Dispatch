# 复制为 .env.development.local 等文件以覆盖本机配置（见 README 与 plan/miniapp/dev/M0-3）
# 禁止在此文件填写 AppSecret、token 等密钥。VITE_* 会打进小程序包，仅可放「可公开的 base URL」。

# 后端 API 根地址（无尾斜杠），与 plan/backend/B0-2 占位一致，域名就绪后替换
VITE_APP_API_BASE_URL=http://127.0.0.1:3000

# 逻辑环境标签：development | staging | production（与 npm script --mode 对应）
VITE_APP_ENV=development

# 是否在控制台输出调试日志（生产构建务必 false）
VITE_APP_DEBUG_LOG=true
