# Staging（复制为服务器上的 .env，勿提交）
NODE_ENV=staging
PORT=3000

# 数据库（建议独立库名）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=clubxcx
DB_PASSWORD=请替换
DB_NAME=clubxcx_staging
DB_SYNC=false
# DB_LOG=true

JWT_SECRET=请替换为强随机串
JWT_EXPIRES_IN=604800

# 与小程序同一小程序 AppID / AppSecret（仅服务器）
WECHAT_MINI_APPID=
WECHAT_MINI_SECRET=
WECHAT_USE_MOCK=false

# 管理端（B1-4），与 .env.example 一致
# ADMIN_USERNAME=
# ADMIN_PASSWORD_HASH=
