# 监听端口（默认 3000）
PORT=3000

# MySQL（与 docker-compose.yml 默认一致）
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=clubxcx
# 开发环境是否自动建表（生产务必 false）
DB_SYNC=true
# DB_LOG=true

# JWT（生产必须更换强随机串）
JWT_SECRET=dev-only-change-me
JWT_EXPIRES_IN=604800

# 微信小程序（与公众平台一致；无则配合 WECHAT_USE_MOCK 本地联调）
WECHAT_MINI_APPID=
WECHAT_MINI_SECRET=
# 设为 true 时跳过请求微信接口（仅开发/CI，openid 由 code 派生 mock）
WECHAT_USE_MOCK=false

# —— 管理端（B1-4）：与小程序分流，账号 + bcrypt 哈希；勿将明文密码提交仓库
# ADMIN_USERNAME=admin
# 生成：node -e "console.log(require('bcrypt').hashSync('你的强密码',10))"
# ADMIN_PASSWORD_HASH=$2b$10$...
# JWT sub 占位（可选）
# ADMIN_JWT_SUB=00000000-0000-4000-8000-000000000001
